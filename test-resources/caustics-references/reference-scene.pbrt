# Caustics Test Scene with BDPT Integrator (PBRT v4)
# Using bidirectional path tracing for proper caustics rendering

LookAt 0 4 8  0 0 0  0 1 0

Camera "perspective"
  "float fov" 45

Film "rgb"
  "string filename" "caustics-bdpt.png"
  "integer xresolution" 800
  "integer yresolution" 600

# BDPT integrator for caustics
Integrator "bdpt"
  "integer maxdepth" 64

Sampler "zsobol"
  "integer pixelsamples" 1024

WorldBegin

# Point light from above
LightSource "point"
  "point3 from" [ 0 10 0 ]
  "rgb I" [ 500 500 500 ]

# Glass sphere at origin
AttributeBegin
  Material "dielectric"
    "float eta" 1.5
  Shape "sphere"
    "float radius" 1.0
AttributeEnd

# Floor plane at Y = -2
AttributeBegin
  Material "diffuse"
    "rgb reflectance" [ 0.8 0.8 0.8 ]
  Translate 0 -2 0
  Shape "trianglemesh"
    "integer indices" [ 0 1 2 0 2 3 ]
    "point3 P" [ -10 0 -10  10 0 -10  10 0 10  -10 0 10 ]
AttributeEnd
