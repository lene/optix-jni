#!/bin/sh
# Pre-commit: fast hygiene checks, target <30s.
# Compile + scalafix only — no tests (pre-push is the correctness gate).
# Native compile is done by pre-push, not pre-commit (too slow for every commit).

# ── Guard: never commit directly to main ──────────────────────────
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ]; then
  echo "ERROR: Committing directly to 'main' is forbidden."
  echo "Use a feature branch and create a PR instead:"
  echo "  git checkout -b feature/my-change"
  echo "  # ... make changes, commit ..."
  echo "  git push origin feature/my-change"
  echo "  # Create PR on GitHub"
  exit 1
fi

RED_TEXT='\e[38;5;196m'
GREEN_TEXT='\e[38;5;46m'
YELLOW_TEXT='\e[38;5;226m'
RESET_TEXT='\e[0m'

STAGED=$(git diff --cached --name-only)
HAS_SCALA=$(echo "$STAGED" | grep -cE '\.(scala|sbt)$|^project/')
HAS_NATIVE=$(echo "$STAGED" | grep -cE 'src/main/native/.*\.(cpp|cu|cuh|h)$|CMakeLists\.txt')

if [ "$HAS_SCALA" -eq 0 ] && [ "$HAS_NATIVE" -eq 0 ]; then
  echo "No code changes staged — skipping."
  exit 0
fi

STATUS=0

# CUDA/OptiX environment check (native changes only — warning, not blocking)
if [ "$HAS_NATIVE" -gt 0 ]; then
  echo "=== CUDA Environment ==="
  if [ -z "$CUDA_HOME" ] || [ ! -x "$CUDA_HOME/bin/nvcc" ]; then
    echo "${YELLOW_TEXT}Warning: CUDA not available — native build will produce stub${RESET_TEXT}"
  else
    echo "CUDA_HOME: ${GREEN_TEXT}$CUDA_HOME${RESET_TEXT}"
    if [ -n "$OPTIX_ROOT" ] && [ -f "$OPTIX_ROOT/include/optix.h" ]; then
      echo "OPTIX_ROOT: ${GREEN_TEXT}$OPTIX_ROOT${RESET_TEXT}"
    else
      echo "${YELLOW_TEXT}Warning: OPTIX_ROOT not set${RESET_TEXT}"
    fi
  fi
fi

echo "=== Compile ==="
sbt compile || STATUS=1

if [ "$HAS_SCALA" -gt 0 ]; then
  echo "=== Scalafix ==="
  sbt "scalafix --check" || STATUS=1
fi

if [ $STATUS -gt 0 ]; then
  commit_msg=$(git log --oneline -1 --format=%s 2>/dev/null || true)
  if echo "$commit_msg" | grep -qi '^WIP:\|^wip:'; then
    echo "WIP commit — proceeding despite failures" >&2
    STATUS=0
  fi
fi

if [ $STATUS -gt 0 ]; then
  echo "pre-commit checks: ${RED_TEXT}FAILED${RESET_TEXT}" >&2
else
  echo "All checks: ${GREEN_TEXT}OK${RESET_TEXT}"
fi
exit $STATUS
